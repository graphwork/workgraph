[15.065178, "o", "\u001b[2;1H\u001b[1m\u001b[38;5;15;48;2;148;134;53mwrite-rust-haiku-3\u001b[4;1H\u001b[22m\u001b[38;5;7;48;2;148;134;53mwrite-rust-haiku-2\u001b[5;42H\u001b[39;49m  \u001b[38;5;8;49m\u250c\u2500 \u001b[1m\u001b[38;5;75;49mBash\u001b[22m\u001b[38;5;8;49m \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[39;49m  \u001b[5;87H    \u001b[5;92H    \u001b[5;97H \u001b[5;99H     \u001b[5;105H        \u001b[6;1H\u001b[38;5;7;48;2;148;134;53mwrite-rust-haiku\u001b[6;44H\u001b[38;5;8;49m\u2502 \u001b[38;5;252;49m$ wg add \"Snacks & movie picks\" -d \"Suggest 3 heist movie picks with\u001b[7;44H\u001b[38;5;8;49m\u2502   \u001b[38;5;252;49mbrief pitches, and pair each with a themed snack or drink idea for team\u001b[8;44H\u001b[38;5;8;49m\u2502 \u001b[8;47H \u001b[38;5;252;49mmovie night.\" && wg add \"Heist debate topics\" -d \"Come up with 3 fun\u001b[9;46H\u001b[38;5;8;49m  \u001b[38;5;252;49mdeb\u001b[9;52Hte\u001b[9;55Hprompt\u001b[9;63Hthe team can argue over during/af\u001b[9;97Her th\u001b[9;104Hmovies (e.g.\u001b[10;49Hest he\u001b[10;56Hst crew role, Oc\u001b[10;74Hn's vs Hea\u001b[10;85H, etc.).\"\u001b[39;49m                         \u001b[11;44H                                                                        \u001b[12;44H\u001b[38;5;8;49m\u250c\u2500\u001b[12;47H\u001b[1m\u001b[38;5;75;49mBash\u001b[22m\u001b[38;5;8;49m \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[39;49m                                \u001b[13;46H\u001b[38;5;252;49m$ wg add \"Full movie night plan\" -d \"Combine the movie picks, snack\u001b[14;44H\u001b[38;5;8;49m\u2502   \u001b[38;5;252;49mpairings, and debate topics into a single shareable team event plan\u001b[15;44H\u001b[