[13.152736, "o", "\u001b[14;44H\u001b[38;5;8;49m\u2514\u2500\u001b[39;49m   \u001b[14;50H  \u001b[16;42H  \u001b[38;5;8;49m\u250c\u2500 \u001b[1m\u001b[38;5;75;49mBash\u001b[22m\u001b[38;5;8;49m \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[39;49m                                    \u001b[17;44H\u001b[38;5;8;49m\u2502 \u001b[38;5;252;49m$ wg add \"Full movie night plan\" -d \"Combine the movie picks, snack\u001b[18;44H\u001b[38;5;8;49m\u2502   \u001b[38;5;252;49mpairings, and debate topics into a single shareable team event plan\u001b[19;44H\u001b[38;5;8;49m\u2502   \u001b[38;5;252;49mwith a fun intro.\" --after snacks-movie-picks,heist-debate-topics\u001b[20;44H\u001b[38;5;124;49m\u21af\u001b[38;5;172;49m\u21af\u001b[38;5;46;49m\u21af\u001b[1m\u001b[38;5;33;49m\u21af\u001b[22m\u001b[38;5;129;49m\u21af\u001b[20;50H\u001b[38;5;8;49m10s\u001b[22;42H\u001b[3m\u001b[38;5;8;48;2;35;32;20m> Plan a heist movie night for the team \u2014 snacks, movie picks, and a debate.\u001b[23m\u001b[2m (\u001b[36;69H\u001b[22m\u001b[39;48;2;30;30;30m                                 \u001b[39m\u001b[49m\u001b[59m\u001b[0m\u001b[?25l"]
