     \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m                                                               \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  \u001b[38;5;8m\u250c\u2500 \u001b[1m\u001b[38;5;75mBash\u001b[0m\u001b[38;5;8m \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[39m                     \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  \u001b[38;5;8m\u2502 \u001b[38;5;252m$ wg add run-load-tests --after add-auth -d \"Run load\u001b[39m      \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  \u001b[38;5;8m\u2502   \u001b[38;5;252mtests against the full search service. Benchmark\u001b[39m         \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  \u001b[38;5;8m\u2502   \u001b[38;5;252mthroughput, latency (p50/p95/p99), and error rates under\u001b[39m \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  \u001b[38;5;8m\u2502   \u001b[38;5;252msustained load.\"\u001b[39m                                         \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  \u001b[38;5;196m\u21af\u001b[1m\u001b[38;5;214m\u21af\u001b[0m\u001b[38;5;46m\u21af\u001b[38;5;25m\u21af\u001b[38;5;91m\u21af\u001b[39m \u001b[38;5;8m23s\u001b[39m                                                    \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m                                                               \u001b[38;5;6m\u2502\r\n\u2502\u001b[1m\u001b[38;5;5m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[0m\u001b[38;5;6m\u2502\r\n\u2502\u001b[1m\u001b[38;5;13m> \u001b[0m\u001b[38;5;0m\u001b[48;5;15m \u001b[39m\u001b[49m                                       