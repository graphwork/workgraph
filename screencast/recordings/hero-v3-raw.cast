\u2014 defines the schema & API contract\u001b[38;5;8m\u2551\u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  \u001b[1mPhase 2:\u001b[0m \u001b[38;5;222m\u001b[48;5;236m build-indexer \u001b[39m\u001b[49m, \u001b[38;5;222m\u001b[48;5;236m build-query-api \u001b[39m\u001b[49m, \u001b[38;5;222m\u001b[48;5;236m setup-storage\u001b[39m\u001b[49m \u001b[38;5;8m\u2551\u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  \u2014 run in parallel                                           \u001b[38;5;8m\u2551\u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  \u001b[1mPhase 3:\u001b[0m \u001b[38;5;222m\u001b[48;5;236m wire-endpoints \u001b[39m\u001b[49m \u2014 integrates all three            \u001b[38;5;8m\u2551\u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  \u001b[1mPhase 4:\u001b[0m \u001b[38;5;222m\u001b[48;5;236m add-auth \u001b[39m\u001b[49m \u2192 \u001b[38;5;222m\u001b[48;5;236m run-load-tests \u001b[39m\u001b[49m \u2014 sequential         \u001b[38;5;8m\u2551\u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  finishing steps                                             \u001b[38;5;15m\u2588\u001b[38;5;6m\u2502\r\n\u2502\u001b[39m                                                              \u001b[38;5;15m\u2588\u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  The service is running and will dispatch agents             \u001b[38;5;15m\u2588\u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  automatically. \u001b[38;5;222m\u001b[48;5;236m design-schema \u001b[39m\u001b[49m is ready to go now.          \u001b[38;5;15m\u2588\u001b[38;5;6m\u2502\r\n\u2502\u001b[39m                                                              \u25bc\u001b[38;5;6m\u2502\r\n\u2502\u001b[38;5;8m \u2191\u2193: scroll\u001b[39m                                                    \u001b[38;5;6m\u2502\r\n\u2514\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u250