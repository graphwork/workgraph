\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2510\r\n\u2502\u001b[38;5;8m \u001b[1m\u001b[38;5;3m0:Chat\u001b[0m\u001b[38;5;8m \u2502 1:Detail \u2502 2:Log \u2502 3:Msg \u2502 4:Agency \u2502 5:Config \u2502 6:Fi\u001b[38;5;6m\u2502\r\n\u2502\u001b[39m \u001b[1m\u001b[38;5;6m \u25c9\u001b[38;5;15m Coordinator 0\u001b[0m \u001b[38;5;8m[+]\u001b[39m                                          \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  \u001b[38;5;8m\u2502   \u001b[38;5;252msustained load.\"\u001b[39m                                         \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  All 7 tasks created. Here's the execution plan:              \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m                                                               \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  \u001b[38;5;8m\u2502 \u001b[38;5;252mdesign-schema\u001b[39m                                              \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  \u001b[38;5;8m\u2502 \u001b[38;5;252m  \u251c\u2500\u2500 build-indexer    \u2500\u2510\u001b[39m                                  \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  \u001b[38;5;8m\u2502 \u001b[38;5;252m\u251c\u2500\u2500 build-query-api \u2500\u253c\u2500\u2500 wire-endpoints \u2192 add-auth \u2192\u001b[39m       \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  \u001b[38;5;8m\u2502   \u001b[38;5;252mrun-load-tests\u001b[39m                                           \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  \u001b[38;5;8m\u2502 \u001b[38;5;252m  \u2514\u2500\u2500 setup-storage    \u2500\u2518\u001b[39m                                  \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m                                                               \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  \u001b[1mPhase 1:\u001b[0m \u001b[38;5;222m\u001b[48;5;236m design-schema \u001b[39m\u001b[49m \u2014 defines the schema & API contract \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  \u001b[1mPhase 2:\u001b[0m \u001b[38;5;222m\u001b[48;5;236m build-indexer \u001b[39m\u001b[49m, \u001b[38;5;222m\u001b[48;5;236m build-query-api \u001b[39m\u001b[49m, \u001b[38;5;222m\u001b[48;5;236m setup-storage\u001b[39m\u001b[49m  \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  \u2014 run in parallel                                            \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  \u001b[1mPhase 3:\u001b[0m \u001b[38;5;222m\u001b[48;5;236m wire-endpoints \u001b[39m\u001b[49m \u2014 integrates all three             \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  \u001b[1mPhase 4:\u001b[0m \u001b[38;5;222m\u001b[48;5;236m add-auth \u001b[39m\u001b[49m \u2192 \u001b[38;5;222m\u001b[48;5;236m run-load-tests \u001b[39m\u001b[49m \u2014 sequential          \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  finishing steps                                              \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m                                                               \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  The service is running and will dispatch agents              \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  automatically. \u001b[38;5;222m\u001b[48;5;236m design-schema \u001b[39m\u001b[49m is ready to go now.           \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m                                                               \u001b[38;5;6m\u2502\r\n\u2502\u001b[38;5;8m \u2191\u2193: scroll\u001b[39m                                                    \u001b[38;5;6m\u2502\r\n\u2514\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2518\r\n\u001b[1m\u001b[38;5;15m\u001b[48;2;30;30;30m Graph\u001b[0m\u001b[38;2;80;80;80m\u001b[48;2;30;30;30m | \u001b[1m\u001b[38;2;120;120;120mNAV\u001b[0m\u001b[38;2;80;80;80m\u001b[48;2;30;30;30m | \u001b[38;5;3m\u2191\u