500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2510\r\n\u2502\u001b[38;5;8m \u001b[1m\u001b[38;5;3m0:Chat\u001b[0m\u001b[38;5;8m \u2502 1:Detail \u2502 2:Log \u2502 3:Msg \u2502 4:Agency \u2502 5:Config \u2502 6:Fi\u001b[38;5;6m\u2502\r\n\u2502\u001b[39m \u001b[1m\u001b[38;5;6m \u25c9\u001b[38;5;15m Coordinator 0\u001b[0m \u001b[38;5;8m[+]\u001b[39m                                          \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  \u001b[38;5;8m\u2502   \u001b[38;5;252mroutes. Wire up request handling, serialization, and\u001b[39m     \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  \u001b[38;5;8m\u2502   \u001b[38;5;252merror responses.\"\u001b[39m                                        \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  \u001b[38;5;8m\u2514\u2500\u001b[39m                                                           \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m                                                               \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  \u001b[38;5;8m\u250c\u2500 \u001b[1m\u001b[38;5;75mBash\u001b[0m\u001b[38;5;8m \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[39m                     \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  \u001b[38;5;8m\u2502 \u001b[38;5;252m$ wg add add-auth --after wire-endpoints -d \"Add\u001b[39m           \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  \u001b[38;5;8m\u2502   \u001b[38;5;252mauthentication and authorization middleware to the\u001b[39m       \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  \u001b[38;5;8m\u2502   \u001b[38;5;252msearch endpoints. Validate tokens, enforce permissions,\u001b[39m  \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  \u001b[38;5;8m\u2502   \u001b[38;5;252mreject unauthorized requests.\"\u001b[39m                           \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  \u001b[38;5;8m\u2514\u2500\u001b[39m                                                      