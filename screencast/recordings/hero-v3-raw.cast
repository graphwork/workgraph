[65.870977, "o", "\u001b[H\u001b[2J\u001b[38;5;15m\u001b[48;5;8m 10 tasks (1 done, 8 open, 1 active) \u001b[38;5;8m| \u001b[38;5;6m\u219138s\u001b[39m \u001b[38;5;5m\u03a30s\u001b[39m \u001b[38;5;4mC:0/160k(0\u001b[38;5;2m\u001b[48;2;20;50;20m \u25cf\u001b[38;5;15m 0/0\r\n\u001b[38;5;7m\u001b[49mdesign-schema\u001b[39m  (open) \u001b[38;5;8m7s\u001b[39m\r\n\u001b[38;5;5m\u251c\u2192\u001b[39m \u001b[38;5;7mbuild-indexer\u001b[39m  (open) \u001b[38;5;8m5s\u001b[39m \u001b[38;5;5m\u2500\u2500\u2500\u2500\u2510\u001b[39m\r\n\u001b[38;5;5m\u251c\u2192\u001b[39m \u001b[38;5;7mbuild-query-api\u001b[39m  (open) \u001b[38;5;8m4s\u001b[39m \u001b[38;5;5m\u2500\u2500\u2524\u001b[39m\r\n\u001b[38;5;5m\u251c\u2192\u001b[39m \u001b[38;5;7msetup-storage\u001b[39m  (open) \u001b[38;5;8m3s\u001b[39m \u001b[38;5;5m\u2500\u2500\u2500\u2500\u2524\u001b[39m\r\n\u001b[38;5;5m\u2514\u2192\u001b[39m \u001b[38;5;7mwire-endpoints\u001b[39m  (open) \u001b[38;5;8m2s\u001b[39m \u001b[38;5;5m\u2190\u2500\u2500\u2518\u001b[39m\r\n  \u001b[38;5;5m\u2514\u2192\u001b[39m \u001b[38;5;7madd-auth\u001b[39m  (open) \u001b[38;5;8m1s\u001b[39m\r\n    \u001b[38;5;5m\u2514\u2192\u001b[39m \u001b[1m\u001b[38;5;15mrun-load-tests\u001b[39m  (open)\u001b[0m \u001b[38;5;8m0s\u001b[39m\r\n\r\n\u001b[38;5;6m\u001b[48;2;0;40;50m.coordinator-0\u001b[39m\u001b[49m  (in-progress) \u001b[38;5;8m38s\u001b[39m [turn 0] \u001b[38;5;8m\u2190\u2500\u2510\u001b[39m\r\n\u001b[38;5;8m\u2514\u2192\u001b[39m \u001b[38;5;7m.compact-0\u001b[39m  (open) \u001b[38;5;8m38s\u001b[39m \u001b[38;5;8m[idle \u00b7 0% ctx]\u001b[39m \u001b[38;5;8m\u2500\u2500\u2500\u2518\u001b[39m\r\n\r\n\r\n\u001b[38;5;6m\u250c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2